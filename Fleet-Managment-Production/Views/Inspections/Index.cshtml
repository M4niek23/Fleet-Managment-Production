@using Fleet_Managment_Production.ViewModels
@model InspectionsViewModel

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Przeglądy</h3>
            <p class="text-muted mb-0">Zarządzaj przeglądami w Twojej flocie.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Dodaj Przegląd
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <input type="hidden" name="activeTab" value="@ViewBag.ActiveTab" />

                <div class="col-auto">
                    <label class="text-secondary small fw-bold">Pojazd:</label>
                </div>
                <div class="col-auto">
                    <select name="vehicleId" class="form-select form-select-sm border-0 shadow-sm" asp-items="ViewBag.VehicleList">
                        <option value="">Wszystkie pojazdy</option>
                    </select>
                </div>
                <div class="col-auto ms-auto">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                           class="form-control form-control-sm border-0 shadow-sm" placeholder="Szukaj rejestracji, marki, modelu..." />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-dark"><i class="bi bi-search"></i></button>
                </div>
                <div class="col-auto">
                    <a asp-action="Index" asp-route-activeTab="@ViewBag.ActiveTab" class="btn btn-sm btn-outline-secondary bg-white border-0 shadow-sm" title="Wyczyść"><i class="bi bi-x-lg"></i></a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-light border-bottom-0 p-0">
            <ul class="nav nav-tabs nav-fill card-header-tabs m-0" id="inspectionTabs">
                <li class="nav-item">
                    <a class="nav-link py-3 fw-bold @(ViewBag.ActiveTab == "active" ? "active" : "")"
                       asp-action="Index" asp-route-activeTab="active"
                       asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-vehicleId="@ViewBag.CurrentVehicleId">
                        <i class="bi bi-check-circle me-2"></i>Aktualne
                        <span class="badge bg-success rounded-pill ms-2">@ViewBag.ActiveTotal</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link py-3 fw-bold text-danger @(ViewBag.ActiveTab == "negative" ? "active" : "")"
                       asp-action="Index" asp-route-activeTab="negative"
                       asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-vehicleId="@ViewBag.CurrentVehicleId">
                        <i class="bi bi-exclamation-triangle me-2"></i>Usterki
                        @if (ViewBag.NegativeTotal > 0)
                        {
                            <span class="badge bg-danger rounded-pill ms-2">@ViewBag.NegativeTotal</span>
                        }
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link py-3 fw-bold text-muted @(ViewBag.ActiveTab == "history" ? "active" : "")"
                       asp-action="Index" asp-route-activeTab="history"
                       asp-route-searchString="@ViewData["CurrentFilter"]" asp-route-vehicleId="@ViewBag.CurrentVehicleId">
                        <i class="bi bi-clock-history me-2"></i>Historia
                        <span class="badge bg-secondary rounded-pill ms-2">@ViewBag.HistoryTotal</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content">
                <div class="tab-pane fade @(ViewBag.ActiveTab == "active" ? "show active" : "")">
                    @await Html.PartialAsync("_InspectionTable", Model.ActiveInspections)
                </div>

                <div class="tab-pane fade @(ViewBag.ActiveTab == "negative" ? "show active" : "")">
                    @await Html.PartialAsync("_InspectionTable", Model.NegativeInspections)
                </div>

                <div class="tab-pane fade @(ViewBag.ActiveTab == "history" ? "show active" : "")">
                    @await Html.PartialAsync("_InspectionTable", Model.HistoricalInspections)
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Nawigacja stronami" class="mt-4 pb-4">
            <ul class="pagination justify-content-center flex-wrap shadow-sm mb-0">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-vehicleId="@ViewBag.CurrentVehicleId"
                       asp-route-activeTab="@ViewBag.ActiveTab">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i"
                           asp-route-searchString="@ViewData["CurrentFilter"]"
                           asp-route-vehicleId="@ViewBag.CurrentVehicleId"
                           asp-route-activeTab="@ViewBag.ActiveTab">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-vehicleId="@ViewBag.CurrentVehicleId"
                       asp-route-activeTab="@ViewBag.ActiveTab">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>