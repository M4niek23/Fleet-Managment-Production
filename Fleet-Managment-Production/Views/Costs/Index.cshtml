@model IEnumerable<Fleet_Managment_Production.Models.Cost>
@using Fleet_Managment_Production.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<Users> UserManager

@{
    ViewData["Title"] = "Rejestr Kosztów";
    var totalSum = ViewBag.TotalSum != null ? (decimal)ViewBag.TotalSum : 0m;
    var currentUserId = UserManager.GetUserId(User);
}

<div class="container-fluid py-4">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Koszty</h2>
            <p class="text-muted mb-0">Ewidencja wydatków floty.</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="bg-white px-3 py-2 rounded shadow-sm border">
                <small class="text-muted d-block text-uppercase" style="font-size:0.7rem;">Suma wydatków</small>
                <span class="fw-bold text-danger fs-5">@totalSum.ToString("C")</span>
            </div>
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Dodaj Koszt
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-muted fw-semibold mb-1" style="font-size: 0.85rem;">Filtruj po kategorii:</label>
                    <select name="filterCategory" asp-for="@ViewData["CurrentFilter"]" class="form-select shadow-sm" asp-items="Html.GetEnumSelectList<Fleet_Managment_Production.Models.CostType>()">
                        <option value="">Wszystkie kategorie</option>
                    </select>
                </div>
                <div class="col-md-2 mt-3 mt-md-0">
                    <button type="submit" class="btn btn-secondary shadow-sm w-100"><i class="bi bi-funnel me-2"></i>Filtruj</button>
                </div>
                <div class="col-md-2 mt-2 mt-md-0">
                    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm w-100">Wyczyść</a>
                </div>
            </form>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Data</th>
                            <th>Pojazd</th>
                            <th>
                                <a asp-action="Index" asp-route-sortOrder="@ViewData["CategorySortParam"]" asp-route-filterCategory="@ViewData["CurrentFilter"]" class="text-dark text-decoration-none">
                                    Kategoria
                                    @if (ViewData["CurrentSort"]?.ToString() == "category_asc")
                                    {
                                        <i class="bi bi-sort-down ms-1 text-primary"></i>
                                    }
                                    else if (ViewData["CurrentSort"]?.ToString() == "category_desc")
                                    {
                                        <i class="bi bi-sort-up ms-1 text-primary"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-down-up ms-1 text-muted" style="font-size: 0.8rem;"></i>
                                    }
                                </a>
                            </th>
                            <th>Szczegóły / Opis</th>
                            <th class="text-end pe-4">Kwota</th>
                            <th class="text-end pe-4">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Brak zarejestrowanych kosztów.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                var canEdit = User.IsInRole("Admin") || User.IsInRole("Manager") ||
                                (item.Vehicle?.Driver != null && item.Vehicle.Driver.UserId == currentUserId);

                                <tr>
                                    <td class="ps-4">@item.Data.ToShortDateString()</td>
                                    <td>
                                        @if (item.Vehicle != null)
                                        {
                                            <div class="fw-bold text-dark">@item.Vehicle.Make @item.Vehicle.Model</div>
                                            <div class="small text-muted">@item.Vehicle.LicensePlate</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Type == CostType.Paliwo)
                                        {
                                            <span class="badge bg-warning text-dark border border-warning">
                                                <i class="bi bi-fuel-pump me-1"></i> Paliwo
                                            </span>
                                        }
                                        else if (item.Type == CostType.Serwis || item.Type == CostType.Przegląd)
                                        {
                                            <span class="badge bg-info text-dark border border-info">
                                                <i class="bi bi-tools me-1"></i> @item.Type
                                            </span>
                                        }
                                        else if (item.Type == CostType.Ubezpieczenie)
                                        {
                                            <span class="badge bg-success border border-success">
                                                <i class="bi bi-shield-check me-1"></i> @item.Type
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark border">@item.Type</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Type == CostType.Paliwo)
                                        {
                                            <div class="d-flex align-items-center gap-2">
                                                @if (item.Liters != null)
                                                {
                                                    <span class="fw-bold text-dark">@item.Liters L</span>
                                                    @if (item.IsFullTank)
                                                    {
                                                        <span class="badge bg-success" style="font-size: 0.6rem;">PEŁNY</span>
                                                    }
                                                }
                                            </div>
                                            @if (item.CurrentOdometer != null)
                                            {
                                                <div class="small text-muted"><i class="bi bi-speedometer2 me-1"></i> @item.CurrentOdometer km</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">@item.Description</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4 fw-bold text-danger">@item.Amount.ToString("C")</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            @if (canEdit && item.Type != CostType.Przegląd && item.Type != CostType.Ubezpieczenie)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Edytuj"><i class="bi bi-pencil"></i></a>
                                            }
                                            @if (User.IsInRole("Admin") && item.Type != CostType.Przegląd && item.Type != CostType.Ubezpieczenie)
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-delete-swal" title="Usuń">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                            else if (item.Type == CostType.Przegląd || item.Type == CostType.Ubezpieczenie)
                                            {
                                                <span class="badge bg-secondary p-2" title="Koszty wygenerowane z systemu, zablokowane"><i class="bi bi-lock"></i> System</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Nawigacja stronami" class="mt-4 pb-4">
            <ul class="pagination justify-content-center flex-wrap shadow-sm mb-0">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-filterCategory="@ViewData["CurrentFilter"]">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-sortOrder="@ViewData["CurrentSort"]"
                           asp-route-filterCategory="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-filterCategory="@ViewData["CurrentFilter"]">
                      <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>