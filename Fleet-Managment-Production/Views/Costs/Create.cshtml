@model Fleet_Managment_Production.Models.Cost
@using Fleet_Managment_Production.Models

@{
    ViewData["Title"] = "Dodaj Nowe Rozliczenie";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Dodaj Rozliczenie</h2>
            <p class="text-muted mb-0">Zarejestruj nową fakturę, paragon lub opłatę.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Powrót do listy
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-wallet2 me-2"></i>Szczegóły wydatku</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">

                    <div class="col-12 text-muted text-uppercase small fw-bold mt-2 mb-2 border-bottom pb-1">
                        Kategoryzacja
                    </div>

                    <div class="col-md-6">
                        <label asp-for="VehicleId" class="form-label fw-bold">Pojazd</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-car-front"></i></span>
                            <select asp-for="VehicleId" class="form-select" asp-items="ViewBag.VehicleId">
                                <option value="">-- Wybierz pojazd --</option>
                            </select>
                        </div>
                        <span asp-validation-for="VehicleId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Type" class="form-label fw-bold">Kategoria kosztu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-tags"></i></span>
                            <select asp-for="Type" class="form-select" asp-items="ViewBag.CostType" id="CostTypeSelect">
                                <option value="">-- Wybierz kategorię --</option>
                            </select>
                        </div>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>

                    <div id="FuelSection" class="col-12" style="display:none;">
                        <div class="p-3 bg-warning bg-opacity-10 border border-warning rounded mt-2">
                            <h6 class="text-dark fw-bold mb-3"><i class="bi bi-fuel-pump me-2"></i>Dane Tankowania</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="Liters" class="form-label fw-bold small">Ilość Litrów</label>
                                    <input asp-for="Liters" class="form-control" placeholder="0.00" type="number" step="0.01" />
                                    <span asp-validation-for="Liters" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="CurrentOdometer" class="form-label fw-bold small">Aktualny Przebieg</label>
                                    <input asp-for="CurrentOdometer" class="form-control" placeholder="km" type="number" />
                                    <span asp-validation-for="CurrentOdometer" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 d-flex align-items-end">
                                    <div class="form-check form-switch mb-2">
                                        <input class="form-check-input" type="checkbox" asp-for="IsFullTank" id="flexSwitchFullTank" checked>
                                        <label class="form-check-label fw-bold" for="flexSwitchFullTank">Tankowanie do pełna</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 text-muted text-uppercase small fw-bold mt-4 mb-2 border-bottom pb-1">
                        Kwota i Termin
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Data" class="form-label fw-bold">Data poniesienia kosztu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-calendar-date"></i></span>
                            <input asp-for="Data" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <span asp-validation-for="Data" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Amount" class="form-label fw-bold">Kwota (PLN)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-cash-stack"></i></span>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="col-12 text-muted text-uppercase small fw-bold mt-4 mb-2 border-bottom pb-1">
                        Szczegóły
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-bold">Opis / Tytuł płatności</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-pen"></i></span>
                            <input asp-for="Description" class="form-control" placeholder="np. Faktura VAT nr..." />
                        </div>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-12 mt-5 d-flex justify-content-end">
                        <a asp-action="Index" class="btn btn-light border me-2">Anuluj</a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">
                            <i class="bi bi-check-lg me-2"></i>Zatwierdź Koszt
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var typeSelect = document.getElementById("CostTypeSelect");
            var fuelSection = document.getElementById("FuelSection");

            function toggleFuelSection() {
                // Pobierz tekst wybranej opcji
                var selectedText = typeSelect.options[typeSelect.selectedIndex].text;

                // Sprawdź czy tekst zawiera słowo "Paliwo" (ignorując wielkość liter)
                if (selectedText.toLowerCase().includes("paliwo")) {
                    fuelSection.style.display = "block";
                } else {
                    fuelSection.style.display = "none";
                }
            }

            // Nasłuchuj zmiany w dropdownie
            typeSelect.addEventListener("change", toggleFuelSection);

            // Uruchom funkcję na starcie (np. gdy walidacja cofnie formularz)
            if(typeSelect.value !== "") {
                toggleFuelSection();
            }
        });
    </script>
}