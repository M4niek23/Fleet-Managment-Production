@model Fleet_Managment_Production.Models.Cost

@{
    ViewData["Title"] = "Szczegóły rozliczenia";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-8 mb-3 mb-md-0">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-4 me-4 d-none d-sm-block">
                        <i class="bi bi-receipt fs-1"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-1">@Html.DisplayFor(model => model.Amount) zł</h2>

                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                            <span class="badge bg-dark fs-6 border border-light shadow-sm">
                                <i class="bi bi-tag me-1"></i>@Html.DisplayFor(model => model.Type)
                            </span>
                            <span class="text-muted">|</span>
                            <span class="text-muted font-monospace small">
                                <i class="bi bi-calendar me-1"></i>@Model.Data.ToShortDateString()
                            </span>
                        </div>

                        <div class="mt-2 text-muted small">
                            <i class="bi bi-car-front me-1"></i> @Html.DisplayNameFor(model => model.Vehicle):
                            <span class="fw-bold text-dark">
                                @(Model.Vehicle?.LicensePlate ?? (Model.Vehicle != null ? $"{Model.Vehicle.Make} {Model.Vehicle.Model}" : "Brak pojazdu"))
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 bg-white">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h6 class="text-muted text-uppercase fw-bold mb-3" style="font-size: 0.75rem;">Akcje</h6>

                    <div class="d-grid gap-2">
                        @if (Model.Type != Fleet_Managment_Production.Models.CostType.Przegląd && Model.Type != Fleet_Managment_Production.Models.CostType.Ubezpieczenie)
                        {
                            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary shadow-sm">
                                <i class="bi bi-pencil-square me-2"></i>Edytuj rozliczenie
                            </a>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Powrót do listy
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom p-4">
            <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i>Dodatkowe informacje</h5>
        </div>
        <div class="card-body p-4">
            <div class="row mb-3 align-items-center">
                <div class="col-sm-3 text-muted">@Html.DisplayNameFor(model => model.Description)</div>
                <div class="col-sm-9 fw-bold">
                    @(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)
                </div>
            </div>
        </div>
    </div>
</div>