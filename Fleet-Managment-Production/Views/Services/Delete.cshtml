@model Fleet_Managment_Production.Models.Service

@{
    ViewData["Title"] = "Usuń Serwis";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1 text-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>Usuń wpis serwisowy
        </h2>
        <p class="text-muted mb-0">Czy na pewno chcesz usunąć ten wpis? <strong class="text-dark">Usunięcie wpisu serwisowego nie zmieni statusu pojazdu.</strong></p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 border-start border-danger border-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4 border-bottom pb-2">Podsumowanie operacji</h5>

                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted fw-normal mb-3">Pojazd:</dt>
                        <dd class="col-sm-8 fw-bold text-dark mb-3">
                            <i class="bi bi-car-front text-primary me-2"></i>@Model.Vehicle?.Make @Model.Vehicle?.Model
                        </dd>

                        <dt class="col-sm-4 text-muted fw-normal mb-3">Data:</dt>
                        <dd class="col-sm-8 fw-medium mb-3">
                            @Model.EntryDate.ToShortDateString()
                        </dd>

                        <dt class="col-sm-4 text-muted fw-normal mb-2">Opis:</dt>
                        <dd class="col-sm-8 mb-2">
                            @Model.Description
                        </dd>
                    </dl>
                </div>

                <div class="card-footer bg-white border-top-0 p-4 pt-0">
                    <hr class="mt-0 mb-4 text-light" />
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Anuluj</a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash-fill me-2"></i>Tak, usuń wpis
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>