@model Fleet_Managment_Production.Models.Service

@{
    ViewData["Title"] = "Szczegóły Serwisu";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-tools text-primary me-2"></i>Szczegóły operacji serwisowej
            </h2>
            <p class="text-muted mb-0">Przegląd informacji o wykonanej naprawie lub obsłudze.</p>
        </div>
        <div>
            @if (!Model.ActualEndDate.HasValue)
            {
                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-4 py-2 fs-6">STATUS: W TRAKCIE</span>
            }
            else
            {
                <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-4 py-2 fs-6">STATUS: ZAKOŃCZONO</span>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4 pb-2">
            <div class="row">

                <div class="col-md-6 mb-4 mb-md-0">
                    <h5 class="fw-bold mb-4 text-dark border-bottom pb-2">Dane operacji serwisowej</h5>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted fw-normal mb-2">Opis:</dt>
                        <dd class="col-sm-8 fw-bold mb-2">@Model.Description</dd>

                        <dt class="col-sm-4 text-muted fw-normal mb-2">Data rozpoczęcia:</dt>
                        <dd class="col-sm-8 mb-2">@Model.EntryDate.ToLongDateString()</dd>

                        <dt class="col-sm-4 text-muted fw-normal mb-2">Data zakończenia:</dt>
                        <dd class="col-sm-8 text-success fw-medium mb-2">@(Model.ActualEndDate?.ToLongDateString() ?? "Nadal w serwisie")</dd>

                        <dt class="col-sm-4 text-muted fw-normal mb-2 mt-2 align-self-center">Koszt całkowity:</dt>
                        <dd class="col-sm-8 h4 text-primary fw-bold mb-2 mt-2">@Model.Cost.ToString("C")</dd>
                    </dl>
                </div>

                <div class="col-md-6 border-start-md ps-md-4">
                    <h5 class="fw-bold mb-4 text-dark border-bottom pb-2">Dane pojazdu</h5>

                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary rounded p-3 me-3">
                            <i class="bi bi-car-front-fill fs-3"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-dark fs-5">@Model.Vehicle?.Make @Model.Vehicle?.Model</div>
                            <div class="text-muted font-monospace fw-semibold">@Model.Vehicle?.LicensePlate</div>
                        </div>
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted fw-normal mb-2">VIN:</dt>
                        <dd class="col-sm-8 font-monospace text-muted small mb-2">@Model.Vehicle?.VIN</dd>

                        <dt class="col-sm-4 text-muted fw-normal mb-2">Aktualny przebieg:</dt>
                        <dd class="col-sm-8 fw-medium mb-2">@Model.Vehicle?.CurrentKm <span class="text-muted small">km</span></dd>
                    </dl>
                </div>

            </div>
        </div>

        <div class="card-footer bg-white border-top-0 p-4">
            <hr class="mt-0 mb-4 text-light" />
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 me-2">Edytuj</a>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Wróć do listy</a>
        </div>
    </div>
</div>

<style>
    /* Klasa pomocnicza dla responywnych ramek (border) */
    @@media (min-width: 768px) {
        .border-start-md {
            border-left: 1px solid #dee2e6 !important;
        }
    }
</style>