@model Fleet_Managment_Production.Models.Service

@{
    ViewData["Title"] = "Dodaj Serwis";
}

<div class="container-fluid py-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-1">
            <i class="bi bi-tools text-primary me-2"></i>Nowy wpis serwisowy
        </h2>
        <p class="text-muted mb-0">Zarejestruj nową usterkę lub zaplanuj obsługę serwisową pojazdu.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-4 mb-md-0 pe-md-4 border-end-md">
                        <h5 class="fw-bold mb-4 text-dark border-bottom pb-2">Informacje podstawowe</h5>

                        <div class="mb-4">
                            <label asp-for="VehicleId" class="form-label fw-semibold text-muted">Pojazd</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white text-muted border-end-0">
                                    <i class="bi bi-car-front"></i>
                                </span>
                                <select asp-for="VehicleId" class="form-select border-start-0" asp-items="ViewBag.VehicleId">
                                    <option value="">-- Wybierz pojazd --</option>
                                </select>
                            </div>
                            <span asp-validation-for="VehicleId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold text-muted">Opis usterki</label>
                            <textarea asp-for="Description" class="form-control shadow-sm" rows="4" placeholder="Opisz dokładnie problem lub zakres planowanych prac..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 ps-md-4">
                        <h5 class="fw-bold mb-4 text-dark border-bottom pb-2">Koszty i Terminy</h5>

                        <div class="row">
                            <div class="col-sm-6 mb-4">
                                <label asp-for="EntryDate" class="form-label fw-semibold text-muted">Data przyjęcia</label>
                                <input asp-for="EntryDate" class="form-control shadow-sm" type="date" />
                                <span asp-validation-for="EntryDate" class="text-danger small"></span>
                            </div>

                            <div class="col-sm-6 mb-4">
                                <label asp-for="PlannedEndDate" class="form-label fw-semibold text-muted">Planowane zakończenie</label>
                                <input asp-for="PlannedEndDate" class="form-control shadow-sm" type="date" />
                                <span asp-validation-for="PlannedEndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Cost" class="form-label fw-semibold text-muted">Szacowany koszt</label>
                            <div class="input-group shadow-sm">
                                <input asp-for="Cost" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span class="input-group-text bg-light">PLN</span>
                            </div>
                            <span asp-validation-for="Cost" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4 text-light" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Anuluj i wróć</a>
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-plus-lg me-2"></i>Dodaj wpis</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    /* Pionowa linia rozdzielająca kolumny na większych ekranach */
    @@media (min-width: 768px) {
        .border-end-md {
            border-right: 1px solid #dee2e6 !important;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}