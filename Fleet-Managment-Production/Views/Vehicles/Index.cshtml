@model IEnumerable<Fleet_Managment_Production.Models.Vehicle>



<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Pojazdy</h2>
            <p class="text-muted mb-0">Zarządzaj flotą samochodową w Twojej firmie.</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Dodaj Pojazd
        </a>
        }
    </div>
    <div class="row mb-4">
    <div class="col-12">
        <form asp-action="Index" method="get" class="card shadow-sm border-0">
            <div class="card-body p-3">
                <div class="row g-2">
                    <div class="col-12 col-md-4">
                        <select name="vehicleId" class="form-select" asp-items="ViewBag.VehicleList">
                            <option value="">Wszyscy kierowcy</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted border-end-0">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                                   class="form-control border-start-0" placeholder="Szukaj marki, rejestracji..." />
                        </div>
                    </div>

                    <div class="col-6 col-md-1 d-grid">
                        <button type="submit" class="btn btn-primary">Filtruj</button>
                    </div>
                    <div class="col-6 col-md-2 d-grid">
                        <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Pojazd</th>
                            <th>Rejestracja / VIN</th>
                            <th>Kierowca</th>
                            <th>Status</th>
                            <th>Przebieg</th>
                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                            {
                                <th class="text-end pe-4">Akcje</th>
                            }
                        </tr>
                    </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="bi bi-info-circle fs-4 d-block mb-2"></i>
                                Nie znaleziono żadnych pojazdów pasujących do wyszukiwania.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                                            <i class="bi bi-car-front-fill fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.Make @item.Model</div>
                                            <div class="text-muted small">@item.ProductionYear • @item.FuelType</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div class="fw-bold">@item.LicensePlate</div>
                                    <div class="text-muted small font-monospace">@item.VIN</div>
                                </td>

                                <td>
                                    @if (item.Driver != null)
                                    {
                                        <div class="fw-bold">@item.Driver.FirstName @item.Driver.LastName</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">Brak przypisanego</span>
                                    }
                                </td>

                                <td>
                                    @switch (item.Status)
                                    {
                                        case Fleet_Managment_Production.Models.VehicleStatus.Available:
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3">Dostępny</span>
                                            break;
                                        case Fleet_Managment_Production.Models.VehicleStatus.InUse:
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary rounded-pill px-3">W trasie</span>
                                            break;
                                        case Fleet_Managment_Production.Models.VehicleStatus.InMaintenance:
                                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3">Serwis</span>
                                            break;
                                        case Fleet_Managment_Production.Models.VehicleStatus.Sold:
                                                <span class="badge bg-gradient bg-opacity-10 text-black border border rounded-pill px-3">Sprzedany</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary rounded-pill">@item.Status</span>
                                        break;
                                    }
                                </td>

                                <td>
                                    <span class="fw-semibold">@item.CurrentKm</span> <span class="text-muted small">km</span>
                                </td>

                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                            {                                            
                                                <a asp-action="Details" asp-route-id="@item.VehicleId" class="btn btn-sm btn-outline-secondary" title="Szczegóły">
                                                <i class="bi bi-eye"></i>
                                                </a>
                                            
                                                <a asp-action="Edit" asp-route-id="@item.VehicleId" class="btn btn-sm btn-outline-secondary" title="Edytuj">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            }
                                            @if(User.IsInRole("Admin"))
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.VehicleId" method="post" class="d-inline">
                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-delete-swal" title="Usuń">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                </table>
            </div>
        </div>
    </div>
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Nawigacja stronami" class="mt-4">
            <ul class="pagination justify-content-center flex-wrap shadow-sm">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>