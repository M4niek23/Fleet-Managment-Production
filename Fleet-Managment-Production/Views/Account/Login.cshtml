@using Fleet_Managment_Production.ViewModels;
@model LoginVM
@{
    ViewData["Title"] = "Logowanie";
}

<div class="row">
    <div class="col-md-5 offset-md-3 my-5">
        <div class="card shadow-sm">
            
            <div class="card-header">
                <h2 class="mb-0 ">Fleet Managment</h2>
            </div>
            
            <div class="card-body">
                <form asp-action="Login">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Username" class="control-label">E-Mail</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Password" class="control-label">Hasło</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <input type="submit" value="Zaloguj się" class="btn btn-primary w-100" />
                    </div>
                    
                    <div class="text-center">
                        <a asp-action="Register" asp-controller="Account">Nie masz konta? Zarejestruj się</a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}