@using Fleet_Managment_Production.Models
@model IEnumerable<Fleet_Managment_Production.Models.Driver>

@{
    ViewData["Title"] = "Kierowcy";
    // Pobieramy aktualny status z kontrolera, aby wiedzieć, która zakładka jest aktywna
    var currentStatus = ViewData["CurrentStatus"] as DriverStatus?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>Kierowcy</h2>
        <p class="text-muted">Baza pracowników i ich uprawnień.</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-dark"><i class="bi bi-person-plus"></i> Dodaj Kierowcę</a>
    }
</div>

@* Sekcja Zakładek (Tabs) *@
@* Sekcja Zakładek (Tabs) *@
<div class="mb-4">
    <ul class="nav nav-tabs border-bottom-0">
        <li class="nav-item">
            <a class="nav-link @(currentStatus == null ? "active bg-primary text-white" : "text-dark")"
               asp-action="Index" asp-route-status="" asp-route-searchString="@ViewData["CurrentFilter"]">Wszyscy</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentStatus == DriverStatus.Active ? "active bg-primary text-white" : "text-dark")"
               asp-action="Index" asp-route-status="@DriverStatus.Active" asp-route-searchString="@ViewData["CurrentFilter"]">Aktywni</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentStatus == DriverStatus.OnLeave ? "active bg-primary text-white" : "text-dark")"
               asp-action="Index" asp-route-status="@DriverStatus.OnLeave" asp-route-searchString="@ViewData["CurrentFilter"]">Na urlopie</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentStatus == DriverStatus.Inactive ? "active bg-primary text-white" : "text-dark")"
               asp-action="Index" asp-route-status="@DriverStatus.Inactive" asp-route-searchString="@ViewData["CurrentFilter"]">Nie pracujący</a>
        </li>
    </ul>
</div>
<form asp-action="Index" method="get" class="mb-4">
    @* Ukryty status, aby szukanie tekstowe nie resetowało wybranej zakładki *@
    <input type="hidden" name="status" value="@currentStatus" />
    <div class="row g-2 align-items-center">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Szukaj po imieniu lub nazwisku..." />
                <button type="submit" class="btn btn-primary">Szukaj</button>
            </div>
        </div>
        <div class="col-md-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
        </div>
    </div>
</form>

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewData["NameSortParm"]"
                       asp-route-searchString="@ViewData["CurrentFilter"]"
                       asp-route-status="@currentStatus"
                       class="text-decoration-none text-dark d-flex align-items-center">
                        Imię i Nazwisko
                        @if (ViewData["NameSortParm"]?.ToString() == "name_desc")
                        {
                            <span class="ms-1">&#9650;</span>
                        }
                        else
                        {
                            <span class="ms-1">&#9660;</span>
                        }
                    </a>
                </th>
                <th>Status</th> @* Nowa kolumna *@
                <th>Kontakt</th>
                <th>Prawo Jazdy</th>
                <th>PESEL</th>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <th class="text-end">Akcje</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">Nie znaleziono kierowców pasujących do kryteriów.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-secondary text-white rounded-circle d-flex justify-content-center align-items-center me-3 fw-bold" style="width: 40px; height: 40px; font-size: 14px;">
                                    @(item.FirstName?.Substring(0, 1))@(item.LastName?.Substring(0, 1))
                                </div>
                                <span class="fw-bold">@item.FirstName @item.LastName</span>
                            </div>
                        </td>
                        <td>
                            @if (item.Status == DriverStatus.Active)
                            {
                                <span class="badge bg-success">Aktywny</span>
                            }
                            else if (item.Status == DriverStatus.OnLeave)
                            {
                                <span class="badge bg-warning text-dark">Na urlopie</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Nie pracujący</span>
                            }
                        </td>
                        <td>
                            <div class="small"><i class="bi bi-envelope text-muted"></i> @item.Email</div>
                            <div class="small"><i class="bi bi-telephone text-muted"></i> @item.PhoneNumber</div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.LicenseCategories))
                            {
                                foreach (var cat in item.LicenseCategories.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge border border-secondary text-dark me-1" style="font-size: 0.75rem;">@cat</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="font-monospace small">@item.Pesel</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Nawigacja stronami" class="mt-4 pb-4">
        <ul class="pagination justify-content-center flex-wrap shadow-sm mb-0">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-sortOrder="@ViewData["CurrentSort"]"
                   asp-route-status="@currentStatus"
                   asp-route-searchString="@ViewData["CurrentFilter"]">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-status="@currentStatus"
                       asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-sortOrder="@ViewData["CurrentSort"]"
                   asp-route-status="@currentStatus"
                   asp-route-searchString="@ViewData["CurrentFilter"]">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}