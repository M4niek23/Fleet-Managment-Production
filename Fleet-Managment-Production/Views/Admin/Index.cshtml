@using Fleet_Managment_Production.Models;
@model IEnumerable<Users>
@using Microsoft.AspNetCore.Identity;
@inject UserManager<Users> UserManager
@{
    ViewData["Title"] = "Panel Administratora";
}
<h2>@ViewData["Title"]</h2>

<table class="table">
    <thead>
        <tr>
            <th>Nick</th>
            <th>Email</th>
            <th>Akcja</th>
            <th>Status konta</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            var roles = await UserManager.GetRolesAsync(user);
            var hasRoles = roles.Any(); 

            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    <a class="btn btn-primary" asp-action="ManageRoles" asp-route-userId="@user.Id">
                        Zarządzaj
                    </a>
                </td>
                <td>
                    @if (user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow)
                    {
                        <form asp-controller="Admin" asp-action="UnlockUser" method="post" class="d-inline ms-1">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Czy na pewno chcesz odblokować to konto?');">
                                <i class="bi bi-unlock-fill"></i> Odblokuj
                            </button>
                        </form>
                    }
                    else if (hasRoles)
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle me-1"></i> Aktywny
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-clock-history me-1"></i> Oczekujący na zatwierdzenie
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>