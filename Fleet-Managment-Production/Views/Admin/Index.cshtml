@using Fleet_Managment_Production.Models;
@model IEnumerable<Users>
@using Microsoft.AspNetCore.Identity;
@inject UserManager<Users> UserManager


<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Panel Administratora</h2>
            <p class="text-muted mb-0">Zarządzanie użytkownikami, rolami i uprawnieniami w systemie.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 border-0 shadow-sm"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]"
                               class="form-control border-start-0 border-0 shadow-sm" placeholder="Szukaj po nazwie, emailu lub nicku..." />
                    </div>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary shadow-sm">Szukaj</button>
                </div>
            </form>
            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <div class="mt-2">
                    <small class="text-muted">Wyniki dla: <strong>@ViewData["CurrentFilter"]</strong></small>
                    <a asp-action="Index" class="text-decoration-none ms-2 small"><i class="bi bi-x-circle"></i> Wyczyść filtry</a>
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" asp-route-searchString="@ViewData["CurrentFilter"]" class="text-decoration-none text-dark fw-bold">
                                Nick / Imię i Nazwisko <i class="bi bi-arrow-down-up ms-1 small text-muted"></i>
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["EmailSortParm"]" asp-route-searchString="@ViewData["CurrentFilter"]" class="text-decoration-none text-dark fw-bold">
                                Email <i class="bi bi-arrow-down-up ms-1 small text-muted"></i>
                            </a>
                        </th>
                        <th>Akcja</th>
                        <th class="text-end pe-4">Status konta</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Brak użytkowników.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            var roles = await UserManager.GetRolesAsync(user);
                            var hasRoles = roles.Any();

                            <tr>
                                <td class="ps-4 fw-bold">@user.UserName <br /><small class="text-muted fw-normal">@user.FullName</small></td>
                                <td>@user.Email</td>

                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <a class="btn btn-outline-primary btn-sm" asp-action="ManageRoles" asp-route-userId="@user.Id">
                                            <i class="bi bi-gear-fill me-1"></i>Zarządzaj
                                        </a>

                                        <form asp-controller="Admin" asp-action="ToggleBlock" method="post" class="m-0">
                                            <input type="hidden" name="id" value="@user.Id" />

                                            @if (user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow)
                                            {
                                                <button type="submit" class="btn btn-outline-success btn-sm" onclick="return confirm('Czy na pewno chcesz odblokować to konto?');">
                                                    <i class="bi bi-unlock-fill me-1"></i>Odblokuj
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Czy na pewno chcesz zablokować to konto? Użytkownik zostanie wylogowany i straci dostęp do systemu.');">
                                                    <i class="bi bi-lock-fill me-1"></i>Zablokuj
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>

                                <td class="text-end pe-4">
                                    @if (user.LockoutEnd.HasValue && user.LockoutEnd.Value > DateTimeOffset.UtcNow)
                                    {
                                        <span class="badge bg-danger shadow-sm">
                                            <i class="bi bi-slash-circle me-1"></i> Zablokowany
                                        </span>
                                    }
                                    else if (hasRoles)
                                    {
                                        <span class="badge bg-success shadow-sm">
                                            <i class="bi bi-check-circle me-1"></i> Aktywny
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark shadow-sm">
                                            <i class="bi bi-clock-history me-1"></i> Oczekujący
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Nawigacja stronami" class="mt-4 pb-4">
            <ul class="pagination justify-content-center flex-wrap shadow-sm mb-0">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-sortOrder="@ViewData["CurrentSort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-sortOrder="@ViewData["CurrentSort"]"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                       <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>